<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0" />
    <title>Meta Photos</title>
    <link
      rel="stylesheet"
      href="/stylesheets/style.css" />
  </head>
  <body>
    <div id="loader-wrapper">
      <div id="loader"></div>
      <div class="loader-section section-left"></div>
      <div class="loader-section section-right"></div>
    </div>
    <div class="container">
      <h1>Meta Photos</h1>
      <div class="card">
        <div class="card_title">
          <h1>Create Account</h1>
          <span>Already have an account? <a href="login">Sign In</a></span>
        </div>
        <div class="form">
          <form
            action="/register"
            method="post">
            <input
              style="color: black"
              type="text"
              name="username"
              id="username"
              required
              placeholder="UserName" />
            <input
              style="color: black"
              type="text"
              name="name"
              required
              id="name"
              placeholder="Name" />
            <input
              style="color: black"
              type="email"
              name="email"
              required
              placeholder="Email"
              id="email" />
            <input
              style="color: black"
              type="password"
              name="password"
              required
              placeholder="Password"
              id="password" />
            <button>Sign Up</button>
          </form>
        </div>
        <div class="card_terms">
          <!-- <input
            type="checkbox"
            name=""
            id="terms" /> -->
          <!-- <span
            >I have read and agree to the <a href="">Terms of Service</a></span
          > -->
          <div class="credit">
            <span
              >Created by
              <a href="https://www.linkedin.com/in/prince-bhatt-0958a725a/"
                >Prince Bhatt</a
              ></span
            >
          </div>
        </div>
      </div>
    </div>
    <script>
      window.addEventListener('load', function () {
        document.body.classList.add('loaded');
      });
    </script>
  </body>
</html>
